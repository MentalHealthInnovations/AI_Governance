{
  "allowedChannelPlugins": [],
  "allowedHttpHookUrls": [],
  "allowedMcpServers": [],
  "allowManagedHooksOnly": true,
  "allowManagedMcpServersOnly": true,
  "allowManagedPermissionRulesOnly": true,
  "alwaysThinkingEnabled": false,
  "channelsEnabled": false,
  "companyAnnouncements": ["You must read and adhere to the MHI Use of Artificial Intelligence policy at https://mentalhealthinnovations.atlassian.net/wiki/spaces/MPSC/pages/4485349381/MHI+Use+of+Artificial+Intelligence. See technical controls at https://github.com/MentalHealthInnovations/AI_Governance"],
  "disableAutoMode": "disable",
  "disableDeepLinkRegistration": "disable",
  "disableSkillShellExecution": true,
  "enabledMcpjsonServers": [],
  "feedbackSurveyRate": 0,
  "forceLoginMethod": "claudeai",
  "forceRemoteSettingsRefresh": true,
  "strictKnownMarketplaces": [],

  "autoConnectIde": false,
  "autoInstallIdeExtension": true,
  "editorMode": "normal",
  "externalEditorContext": true,
  "showTurnDuration": true,
  "terminalProgressBarEnabled": true,

  "permissions": {
    "additionalDirectories": [],
    "defaultMode": "plan",
    "disableBypassPermissionsMode": "disable",
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.azure/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.npmrc)",
      "Read(~/.netrc)",
      "Read(~/.docker/config.json)",
      "Read(~/.kube/config)",
      "Read(~/.terraform.d/**)",
      "Read(~/.vault-token)",
      "Read(~/.config/gh/hosts.yml)",
      "Read(~/.pypirc)",
      "Read(~/.gem/credentials)",
      "Read(~/.cargo/credentials)",
      "Read(~/.config/op/**)",

      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./secrets/**)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/*.p12)",
      "Read(./**/*.pfx)",
      "Read(./**/*.jks)",
      "Read(./**/id_rsa)",
      "Read(./**/id_ecdsa)",
      "Read(./**/id_ed25519)",
      "Read(./**/*_rsa)",
      "Read(./**/*credentials*)",
      "Read(./**/*secret*)",
      "Read(./**/*token*)",

      "Read(/etc/passwd)",
      "Read(/etc/shadow)",

      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(./**/.env)",
      "Edit(./**/.env.*)",
      "Edit(./secrets/**)",
      "Edit(./**/*.pem)",
      "Edit(./**/*.key)",
      "Edit(./**/*.p12)",
      "Edit(./**/*.pfx)",
      "Edit(./**/*.jks)",
      "Edit(./**/id_rsa)",
      "Edit(./**/id_ecdsa)",
      "Edit(./**/id_ed25519)",
      "Edit(./**/*_rsa)",
      "Edit(./**/*credentials*)",
      "Edit(./**/*secret*)",
      "Edit(./**/*token*)",

      "Edit(./.git/hooks/**)",
      "Edit(./.git/config)",
      "Edit(./.git/HEAD)",
      "Edit(./.git/ORIG_HEAD)",
      "Edit(./.git/packed-refs)",
      "Edit(./.husky/**)",
      "Edit(/Library/Application Support/ClaudeCode)",

      "WebSearch(*)"
    ]
  },

  "sandbox": {
    "enabled": true,
    "enableWeakerNestedSandbox": false,
    "enableWeakerNetworkIsolation": false,
    "ignoreViolations": {},
    "autoAllowBashIfSandboxed": false,
    "excludedCommands": [],
    "allowUnsandboxedCommands": false,

    "filesystem": {
      "allowRead": [
        "."
      ],
      "allowWrite": [
        ".",
        "./tmp",
        "./build",
        "./dist",
        "./coverage",
        "./.git/refs/**",
        "./.git/objects/**",
        "./.git/logs/**",
        "./.git/COMMIT_EDITMSG",
        "./.git/MERGE_MSG",
        "./.git/MERGE_HEAD",
        "./.git/index",
        "./.git/FETCH_HEAD"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.azure",
        "~/.config/gcloud",
        "~/.gnupg",
        "~/.npmrc",
        "~/.netrc",
        "~/.docker",
        "~/.kube",
        "~/.terraform.d",
        "~/.vault-token",
        "~/Library/Keychains",
        "~/.config/gh",
        "~/.pypirc",
        "~/.gem",
        "~/.cargo/credentials",
        "~/.config/op"
      ],
      "denyWrite": [
        "/etc",
        "/usr/local/bin",
        "~/.ssh",
        "~/.aws",
        "~/.azure",
        "~/.config/gcloud",
        "~/.gnupg",
        "~/.npmrc",
        "~/.netrc",
        "~/.docker",
        "~/.kube",
        "~/.terraform.d",
        "~/.vault-token",
        "~/Library/Keychains"
      ],
      "allowManagedReadPathsOnly": true
    },

    "network": {
      "allowUnixSockets": [],
      "allowAllUnixSockets": false,
      "allowLocalBinding": false,
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "objects.githubusercontent.com",
        "raw.githubusercontent.com",
        "registry.npmjs.org",
        "pypi.org",
        "files.pythonhosted.org",
        "proxy.golang.org",
        "crates.io",
        "index.crates.io",
        "registry-1.docker.io",
        "auth.docker.io",
        "production.cloudflare.docker.com",
        "mentalhealthinnovations.org",
        "themix.org.uk",
        "giveusashout.org",
        "code.claude.com"
      ],
      "allowManagedDomainsOnly": true
    }
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/claude/hooks/bash-policy-check.sh"
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/claude/hooks/webfetch-policy-check.sh"
          }
        ]
      }
    ]
  }
}
