{
  "allowManagedHooksOnly": true,
  "allowManagedMcpServersOnly": true,
  "defaultMode": "auto",
  "disableBypassPermissionsMode": true,
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "/opt/claude/hooks/bash-policy-check.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "/opt/claude/hooks/cc-redact-wrapper.sh",
            "type": "command"
          }
        ],
        "matcher": "Read"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(gitstatus*)",
      "Bash(gitdiff*)",
      "Bash(gitlog*)",
      "Bash(gitbranch*)",
      "Bash(gitcheckout-b*)",
      "Bash(ghprview*)",
      "Bash(ghissueview*)",
      "Bash(ghrepoview*)",
      "Bash(npmtest*)",
      "Bash(npmruntest*)",
      "Bash(npmrunlint*)",
      "Bash(npmruntypecheck*)",
      "Bash(pnpmtest*)",
      "Bash(pnpmlint*)",
      "Bash(pytest*)",
      "Bash(ruffcheck*)",
      "Bash(mypy*)",
      "Bash(gotest*)",
      "Bash(cargotest*)"
    ],
    "ask": [
      "Bash(gitpush*)",
      "Bash(ghprcreate*)",
      "Bash(ghprmerge*)",
      "Bash(npminstall*)",
      "Bash(pnpmadd*)",
      "Bash(yarnadd*)",
      "Bash(pipinstall*)",
      "Bash(poetryadd*)",
      "Bash(goget*)",
      "Bash(cargoadd*)",
      "Bash(dockerbuild*)",
      "Bash(dockerrun*)"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.azure/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.npmrc)",
      "Read(~/.netrc)",
      "Read(~/.docker/config.json)",
      "Read(~/.kube/config)",
      "Read(~/.terraform.d/**)",
      "Read(~/.vault-token)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./secrets/**)",
      "Read(/etc/passwd)",
      "Read(/etc/shadow)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(./**/.env)",
      "Edit(./**/.env.*)",
      "Edit(./secrets/**)",
      "Edit(./.git/**)",
      "Edit(./.husky/**)",
      "Bash(curl*)",
      "Bash(wget*)",
      "Bash(nc*)",
      "Bash(netcat*)",
      "Bash(ncat*)",
      "Bash(socat*)",
      "Bash(sudo*)",
      "Bash(su*)",
      "Bash(rm-rf*)",
      "Bash(gitpush--force*)",
      "Bash(*|bash*)",
      "Bash(*|sh*)",
      "Bash(*|zsh*)",
      "Bash(*|fish*)",
      "Bash(*|python*)",
      "Bash(*|node*)",
      "Bash(eval*)",
      "Bash(xargs*)"
    ]
  },
  "sandbox": {
    "allowUnsandboxedCommands": false,
    "autoAllowBashIfSandboxed": false,
    "enabled": true,
    "filesystem": {
      "allowManagedReadPathsOnly": true,
      "allowRead": [
        "."
      ],
      "allowWrite": [
        ".",
        "./tmp",
        "./build",
        "./dist",
        "./coverage"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.azure",
        "~/.config/gcloud",
        "~/.gnupg",
        "~/.npmrc",
        "~/.netrc",
        "~/.docker",
        "~/.kube",
        "~/.terraform.d",
        "~/.vault-token",
        "~/Library/Keychains"
      ],
      "denyWrite": [
        "/etc",
        "/usr/local/bin",
        "~/.ssh",
        "~/.gnupg"
      ]
    },
    "network": {
      "allowAllUnixSockets": false,
      "allowLocalBinding": false,
      "allowManagedDomainsOnly": true,
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "objects.githubusercontent.com",
        "raw.githubusercontent.com",
        "registry.npmjs.org",
        "pypi.org",
        "files.pythonhosted.org",
        "proxy.golang.org",
        "crates.io",
        "index.crates.io",
        "registry-1.docker.io",
        "auth.docker.io",
        "production.cloudflare.docker.com"
      ]
    }
  }
}
